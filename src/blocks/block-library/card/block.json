{
	"$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/block.json",
	"apiVersion": 3,
	"name": "ystdb/card",
	"title": "カード",
	"description": "カード型リンクを作成するブロック",
	"category": "ystdb",
	"keywords": [ "card", "カード", "blogcard", "ブログカード" ],
	"attributes": {
		"url": {
			"type": "string"
		},
		"linkTarget": {
			"type": "string"
		},
		"rel": {
			"type": "string"
		},
		"cardType": {
			"type": "string",
			"default": "horizon"
		},
		"title": {
			"type": "string"
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"imageSize": {
			"type": "string"
		},
		"imageType": {
			"type": "string"
		},
		"imageAlign": {
			"type": "string",
			"default": "left"
		},
		"imageURL": {
			"type": "string"
		},
		"imageAlt": {
			"type": "string"
		},
		"imageID": {
			"type": "integer",
			"default": 0
		},
		"showDscr": {
			"type": "boolean",
			"default": true
		},
		"dscrCharCount": {
			"type": "number",
			"default": 80
		},
		"dscr": {
			"type": "string"
		},
		"showDomain": {
			"type": "boolean",
			"default": true
		},
		"backgroundColor": {
			"type": "string"
		},
		"customBackgroundColor": {
			"type": "string"
		},
		"borderColor": {
			"type": "string"
		},
		"customBorderColor": {
			"type": "string"
		},
		"titleColor": {
			"type": "string"
		},
		"customTitleColor": {
			"type": "string"
		},
		"dscrColor": {
			"type": "string"
		},
		"customDscrColor": {
			"type": "string"
		},
		"domainColor": {
			"type": "string"
		},
		"customDomainColor": {
			"type": "string"
		},
		"caption": {
			"type": "string"
		}
	},
	"supports": {
		"className": false,
		"html": false,
		"align": false
	},
	"example": {
		"attributes": {
			"url": "https://wp-ystandard.com/"
		}
	},
	"textdomain": "ystandard-blocks",
	"editorScript": "file:./index.tsx",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
